{
  "name": "@api-contract-diff/engine",
  "version": "1.1.0",
  "type": "module",
  "description": "API Contract Diff engine — detects breaking and non-breaking changes between OpenAPI specs",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "cli": "tsx src/cli.ts",
    "test:node": "tsx --test tests/*.test.ts"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
